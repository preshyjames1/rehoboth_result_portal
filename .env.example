# ============================================================
# REHOBOTH COLLEGE RESULT PORTAL — Environment Variables
# Copy this file to .env.local for local development.
# All variables below must also be set in Vercel dashboard
# under Settings → Environment Variables → Production.
# ============================================================

# ── Supabase ─────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── Auth / Session ────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=your-64-char-random-hex-string

# ── Paystack ─────────────────────────────────────────────────
PAYSTACK_SECRET_KEY=sk_live_...
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_live_...
# Your Paystack webhook secret — from Paystack Dashboard → Settings → Webhooks
# This is typically the same as PAYSTACK_SECRET_KEY for Paystack
PAYSTACK_WEBHOOK_SECRET=sk_live_...

# ── PIN Pricing ───────────────────────────────────────────────
# Amount in kobo (₦700 = 70000 kobo)
PIN_PRICE_KOBO=70000
NEXT_PUBLIC_PIN_PRICE_KOBO=70000

# ── Site URL ─────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://result.schuwap.xyz
# Legacy alias — keep both set
NEXT_PUBLIC_APP_URL=https://result.schuwap.xyz

# ── Email (Resend) ────────────────────────────────────────────
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=noreply@schuwap.xyz

# ── Cron Job ─────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Must also be set as the "Authorization" header value in cron-job.org
# The header name in the app is: x-cron-secret
CRON_SECRET=your-32-char-random-hex-string

# ── Upstash Redis (Rate Limiting) ─────────────────────────────
# Create a free database at console.upstash.com
# Copy both values from the database dashboard → REST API section
UPSTASH_REDIS_REST_URL=https://YOUR_DB.upstash.io
UPSTASH_REDIS_REST_TOKEN=AXX...

# ── Upload Limits ─────────────────────────────────────────────
MAX_BULK_ZIP_SIZE_MB=50
